{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,

    "isolatedModules": true,
    "moduleDetection": "force",

    "allowJs": true,
    "allowImportingTsExtensions": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "types": ["vite/client"],

    "noEmit": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  },

  "include": ["src", "src/**/*.d.ts"]
}
